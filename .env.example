# ─── Airtable ─────────────────────────────────────────────
# Trouvez ces valeurs dans : airtable.com/account (API key)
# et dans l'URL de votre base (appXXXXXXXXXXXXXX)

AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Noms exacts des tables dans votre base Airtable
AIRTABLE_EMPLOYEE_TABLE=Employee Analytics
AIRTABLE_DEPARTMENT_TABLE=Department_rollups
AIRTABLE_EXECUTIVE_TABLE=Executive_Summaries

# ─── Make webhook (Ask Stance) ────────────────────────────
# Paste the "instant" webhook URL from your Make scenario.
# The scenario must return JSON: { summary, risk_level, recommendations[], confidence_score }
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Serveur ──────────────────────────────────────────────
PORT=3000
